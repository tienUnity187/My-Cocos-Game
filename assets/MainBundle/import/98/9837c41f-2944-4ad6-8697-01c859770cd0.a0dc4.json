,0,0,5.964]],[52,"Title",false,9,[0,"13JjoYuH1EfoWSCgBOoahM"],[4,4278910779]],[53,"All symbols pay from left to right on adjacent reels starting from the leftmost reel.\n",1,1,25,1920,false,10,[0,"a7H3Dwv4xNG6mL1tO99PcF"]],[21,28,"These symbols are WILD and substitute for all symbols except for BONUS.\n\nThey can appear on all reels during base game and FREE SPINS feature.\n\n<img src = 'symbol_5' width=100 height=60 offset=-13 />  multiplies by 3x the win of all winning combinations that it is part of except for jackpot wins.\n\nThe game has four fixed jackpots: MINI, MINOR, MAJOR, and GRAND.\n\nHit any 3 WILD symbols combination of any kind on a payline to trigger the MINI jackpot and win 25x total bet.\n\nHit 3   <img src = 'symbol_8' width=80 height=50 offset=-13/>  on a payline to trigger MINOR jackpot and win 100x total bet.\n\nHit 3   <img src = 'symbol_7' width=80 height=50 offset=-13 />  on a payline to trigger the MAJOR jackpot and win 250x total bet.\n\nHit 3   <img src = 'symbol_5' width=80 height=50 offset=-13 />  on a payline to trigger the GRAND jackpot and win 500x total bet.\n\nMaximum one jackpot can be won in a single spin.",1,24,1900,false,11,[0,"9azgNBT+lG/JGl5KQjs3Jd"]],[13,"3-7x",22,22,false,30,[0,"f4zo4r0EhJraD5+XywZW5a"]],[13,"3-4x",22,22,false,32,[0,"c6uXF43S5IFaOqsKyqna7U"]],[13,"3-2.5x",22,22,false,34,[0,"57mIodX35EyItMohaymt4Q"]],[13,"3-1x",22,22,false,36,[0,"83GseIkg5EU5jKhSqQYJut"]],[13,"3-1x",22,22,false,39,[0,"1e3PddFH9GGr81UYQaCONk"]],[13,"3-0.5x",22,22,false,41,[0,"9fvEkS2E5BMYTbRl8wzUY9"]],[13,"3-0.3x",22,22,false,43,[0,"c0KrjCYIVC661fA7qSuPoc"]],[22,false,13,[0,"e2c3b0OWBEKJ3L7ADi4C9r"],[4,4278910779]],[21,28,"This is the BONUS symbol. It can appear only on reel 3.\nWhen BONUS symbol hits the FREE SPINS feature is triggered and 10 free spins are awarded.\nDuring the round, on each spin a multiplier from 2x to 20x is randomly selected and applies\nto the total win of the current spin including the jackpot wins.\nWhen BONUS symbol hits during the round 10 additional free spins are awarded.\nSpecial reels are in play during the round.\n",1,24,1700,false,14,[0,"b7Z7skUN1E25p0ZcQK2mXz"]],[22,false,15,[0,"e0kiDooK1GzK2myUPuPsmJ"],[4,4278910779]],[21,28,"The maximum win amount is limited to <color=#FDE900> 5,000x bet.</color><color=#FFFFFF>\nIf the total win of a round reaches <color=#FDE900>10,000x </color>bet the round immediately ends, \nwin is awarded and all remaining features are forfeited.</color>tyty\n\n",1,24,1700,false,16,[0,"02Y8YTGCZM6oJupD7yxY4j"]],[22,false,17,[0,"c31HNIuI1AT5JFv1g5CDGu"],[4,4278910779]],[21,28,"\"The FREE SPINS round can be instantly triggered from the base game by buying it.\nPay 100x total bet to trigger the FREE SPINS feature.\"\n",1,24,1700,false,18,[0,"49qyuq7w5ADJV/s3zq8ftX"]],[22,false,19,[0,"82esTNgsNKQ58wj5/llyPY"],[4,4278910779]],[34,28,"High volatility games pay out less often on average but the chance to hit big wins in a short time span is higher.\nAll symbols pay from left to right on selected paylines.\nAll wins are multiplied by bet per line.\nFree spins wins are added to the payline win.\nAll values are expressed as actual wins in coins.\nOnly the highest win is paid per line.\nWhen winning on multiple paylines, all wins are added to the total win.\n\nFree spins win is awarded to the player after the round completes.\n",1,1,24,1700,false,20,[0,"6fFUJWVgZJWaYjPMhR+Y1L"]],[34,28,"The theoretical RTP of this game is <color=#FDE900>95.53%</color><color=#FFFFFF>\nThe RTP of the game when using \"BUY FREE SPINS\" is</color> <color=#FDE900>95.53%</color>\nSPACE buttons on the keyboard can be used to start and stop the spin.\nMalfunction voids all pays and plays.",1,1,24,1700,false,21,[0,"fe4+KpaP9FDJebyMHzGNg6"]],[28,22,[0,"45UCcZXrJBz6SLdNtg92zx"]],[28,23,[0,"64anRgpo5NvpbWELzaMd9+"]],[28,24,[0,"35D+jjmBVCV4zGjz2u3iea"]]],0,[0,7,1,0,0,1,0,8,64,0,9,63,0,10,62,0,11,61,0,12,60,0,13,59,0,14,58,0,15,73,0,16,72,0,17,71,0,18,70,0,19,68,0,20,66,0,21,69,0,22,67,0,