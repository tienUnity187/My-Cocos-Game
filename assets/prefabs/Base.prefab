    "_enabled": true,
    "__prefab": {
      "__id__": 3990
    },
    "_lineHeight": 28,
    "_string": "This is the BONUS symbol. It can appear only on reel 3.\nWhen BONUS symbol hits the FREE SPINS feature is triggered and 10 free spins are awarded.\nDuring the round, on each spin a multiplier from 2x to 20x is randomly selected and applies\nto the total win of the current spin including the jackpot wins.\nWhen BONUS symbol hits during the round 10 additional free spins are awarded.\nSpecial reels are in play during the round.\n",
    "_horizontalAlign": 1,
    "_verticalAlign": 1,
    "_fontSize": 24,
    "_fontColor": {
      "__type__": "cc.Color",
