  {
    "__type__": "cc.RichText",
    "_name": "",
    "_objFlags": 0,
    "__editorExtras__": {},
    "node": {
      "__id__": 1518
    },
    "_enabled": true,
    "__prefab": null,
    "_lineHeight": 28,
    "_string": "High volatility games pay out less often on average but the chance to hit big wins in a short time span is higher.\nAll symbols pay from left to right on selected paylines.\nAll wins are multiplied by bet per line.\nFree spins wins are added to the payline win.\nAll values are expressed as actual wins in coins.\nOnly the highest win is paid per line.\nWhen winning on multiple paylines, all wins are added to the total win.\n\nFree spins win is awarded to the player after the round completes.\n",
    "_horizontalAlign": 1,
    "_verticalAlign": 1,
    "_fontSize": 22,
    "_fontColor": {
      "__type__": "cc.Color",
      "r": 255,
      "g": 255,
      "b": 255,
      "a": 255
    },
    "_maxWidth": 0,
