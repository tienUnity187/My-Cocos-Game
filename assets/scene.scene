  {
    "__type__": "cc.RichText",
    "_name": "",
    "_objFlags": 0,
    "__editorExtras__": {},
    "node": {
      "__id__": 1404
    },
    "_enabled": true,
    "__prefab": null,
    "_lineHeight": 28,
    "_string": "These symbols are WILD and substitute for all symbols except for BONUS.\n\nThey can appear on all reels during base game and FREE SPINS feature.\n\n<img src = 'symbol_5' width=100 height=60 offset=-13 />  multiplies by 3x the win of all winning combinations that it is part of except for jackpot wins.\n\nThe game has four fixed jackpots: MINI, MINOR, MAJOR, and GRAND.\n\nHit any 3 WILD symbols combination of any kind on a payline to trigger the MINI jackpot and win 25x total bet.\n\nHit 3   <img src = 'symbol_8' width=80 height=50 offset=-13/>  on a payline to trigger MINOR jackpot and win 100x total bet.\n\nHit 3   <img src = 'symbol_7' width=80 height=50 offset=-13 />  on a payline to trigger the MAJOR jackpot and win 250x total bet.\n\nHit 3   <img src = 'symbol_5' width=80 height=50 offset=-13 />  on a payline to trigger the GRAND jackpot and win 500x total bet.\n\nMaximum one jackpot can be won in a single spin.",
    "_horizontalAlign": 1,
    "_verticalAlign": 1,
    "_fontSize": 22,
    "_fontColor": {
      "__type__": "cc.Color",
      "r": 255,
      "g": 255,
      "b": 255,
      "a": 255
    },
    "_maxWidth": 0,
    "_fontFamily": "Arial",
    "_font": {
      "__uuid__": "a2cc7d7d-0672-4197-ad4f-735bd204840f",
      "__expectedType__": "cc.TTFFont"
    },
